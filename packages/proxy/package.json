{
  "name": "@db-studio/proxy",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "portless run",
    "dev:app": "wrangler dev --port=${PORT:-8787}",
    "build": "wrangler build",
    "start": "portless proxy.dbstuio bun run start:app",
    "start:app": "bun run build && wrangler dev --remote --port=${PORT:-8787}",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "format": "biome check --write --unsafe",
    "secrets:add": "wrangler secret bulk .env",
    "secrets:list": "wrangler secret list",
    "secrets:clear": "wrangler secret delete --all"
  },
  "portless": {
    "name": "proxy.dbstuio",
    "script": "dev:app"
  },
  "dependencies": {
    "@db-studio/shared": "workspace:*",
    "@tanstack/ai": "^0.14.0",
    "@tanstack/ai-gemini": "^0.10.0",
    "@upstash/redis": "^1.36.1",
    "hono": "^4.11.3",
    "hono-rate-limiter": "^0.5.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.6",
    "wrangler": "^4.4.0"
  }
}
